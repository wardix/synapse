{
  "name": "synapse",
  "description": "Knowledge base platform with RAG capabilities",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "bun run dev:server & bun run dev:client",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "cd client && bun run dev",
    "build": "cd client && bun run build",
    "migrate": "bun run server/db/migrate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "husky": "^9.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.26",
    "jose": "^6.2.3"
  }
}
