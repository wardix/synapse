commit_msg=$(cat "$1")

# Conventional Commits pattern: type(scope): description
pattern="^(feat|fix|chore|docs|refactor|test|style|perf|ci|build|revert)(\(.+\))?: .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Expected: <type>: <description>"
  echo ""
  echo "Types: feat, fix, chore, docs, refactor, test, style, perf, ci, build, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add semantic search endpoint"
  echo "  fix: handle empty search query"
  echo "  chore: update dependencies"
  echo "  docs: add API usage examples"
  echo ""
  exit 1
fi
