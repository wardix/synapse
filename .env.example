# Deployment Mode
NODE_ENV=production

# Database (For Docker Compose, postgres runs on the postgres service hostname)
DATABASE_URL=postgres://synapse:synapse@postgres:5432/synapse

# PostgreSQL Credentials (Must match DATABASE_URL)
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# JWT
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
